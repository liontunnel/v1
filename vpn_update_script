# Spinner animation
spinner() {
    while true; do
        for i in "${SPINNER[@]}"; do
            echo -ne "\r${BLUE}[${i}] ${YELLOW}Installing...${NC} "
            sleep 0.1
        done
    done
}

# Main installation
main_install() {
    # Start spinner animation
    spinner &
    SPINNER_PID=$!
    
    # 1. Install PPTP/L2TP/SSTP
    echo -e "\n${YELLOW}‚Ė∂ Installing PPTP/L2TP/SSTP/WIREGUARD & TROJANGO...${NC}"
    cd
    rm -f installer-sstp.sh
    wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/installer-sstp.sh
    wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/installer-wg.sh
    wget -q https://raw.githubusercontent.com/king-vpn/autoscript-vip/refs/heads/main/install/ins-trgo.sh
    chmod +x installer-sstp.sh
    chmod +x installer-wg.sh
    chmod +x ins-trgo.sh
    sudo ./installer-sstp.sh
    sudo ./installer-wg.sh
    sudo ./ins-trgo.sh
    rm -f installer-sstp.sh
    rm -f installer-wg.sh
    rm -f ins-trgo.sh
    echo -e "${GREEN}‚úĒ PPTP/L2TP/SSTP/WIREGUARD & TROJANGO installed successfully${NC}"
    
    # 2. Install System Updates
    echo -e "\n${YELLOW}‚Ė∂ Installing System Updates...${NC}"
    cd
    rm -f alpha2_update
    wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/script2_update
    chmod +x script2_update
    ./script2_update
    rm -f script2_update
    echo -e "${GREEN}‚úĒ System Updates installed successfully${NC}"
    
    # 3. Install VPN Menu & Menu Backup to /usr/local/sbin
    echo -e "\n${YELLOW}‚Ė∂ Installing Data Menu Update /usr/local/sbin...${NC}"
    sudo mkdir -p /usr/local/sbin
    cd /usr/local/sbin
    sudo rm -f vpn
    sudo rm -f backup
    sudo rm -f restore
    sudo rm -f delws
    sudo wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/backup
    sudo wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/restore
    sudo wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/vpn
    sudo wget -q https://raw.githubusercontent.com/liontunnel/v1/refs/heads/main/delws
    sudo chmod +x backup
    sudo chmod +x restore
    sudo chmod +x vpn
    sudo chmod +x delws
    cd
    echo -e "${GREEN}‚úĒ VPN Menu installed to /usr/local/sbin/vpn${NC}"

    # Stop spinner
    kill $SPINNER_PID
    wait $SPINNER_PID 2>/dev/null
    # 4. Install BACKUP & RESTORE /usr/local/sbin
    sudo apt-get install dos2unix -y
    sudo dos2unix /usr/local/sbin/backup
    sudo dos2unix /usr/local/sbin/restore
     cd
    echo -e "${GREEN}‚úĒ BACKUP & RESTORE /usr/local/sbin/backup&restore${NC}"
    # Completion message
    echo -e "\n${YELLOW}------------------------------------------${NC}"
    echo -e "${GREEN}‚úĒ All installations completed successfully!${NC}"
    echo -e "${YELLOW}------------------------------------------${NC}"
    
    # Self-cleanup
    echo -e "\n${YELLOW}Cleaning up installer...${NC}"
    sleep 2
    rm -f "$0"
}

# Start installation
show_header
main_install
